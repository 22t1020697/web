@model SV22T1020697.Models.Partner.Customer
@using SV22T1020697.Shop
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container mt-5 mb-5" style="max-width: 1100px;">

    <div class="row mb-4 align-items-center">
        <div class="col-12 text-center text-md-start">
            <h2 class="fw-bolder text-dark mb-1">
                <i class="fa-solid fa-id-card text-primary me-2"></i>Quản lý hồ sơ
            </h2>
            <p class="text-muted mb-0">Quản lý thông tin bảo mật và cài đặt cá nhân của bạn</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 d-flex align-items-center" role="alert">
                    <i class="fa-solid fa-circle-check fs-4 me-3"></i>
                    <div>
                        <strong>Thành công!</strong> @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 d-flex align-items-center" role="alert">
                    <i class="fa-solid fa-triangle-exclamation fs-4 me-3"></i>
                    <div>
                        <strong>Có lỗi xảy ra!</strong> @TempData["Error"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 text-center overflow-hidden h-100">
                <div style="height: 120px; background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);"></div>

                <div class="card-body px-4 pb-4 position-relative" style="margin-top: -60px;">
                    <div class="d-inline-flex align-items-center justify-content-center text-white rounded-circle shadow border border-4 border-white mb-3 position-relative"
                         style="width: 110px; height: 110px; font-size: 45px; font-weight: bold; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); z-index: 1;">
                        @(string.IsNullOrEmpty(Model.CustomerName) ? "U" : Model.CustomerName.Substring(0, 1).ToUpper())
                    </div>

                    <h4 class="fw-bold mb-1 text-dark">@Model.CustomerName</h4>
                    <p class="text-muted mb-3"><i class="fa-regular fa-envelope me-2"></i>@Model.Email</p>

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-3 py-2 rounded-pill">
                            <i class="fa-solid fa-star text-warning me-1"></i> Khách hàng thành viên
                        </span>
                    </div>

                    <hr class="text-muted opacity-25">

                    <div class="text-start mt-4">
                        <p class="text-muted small fw-bold text-uppercase mb-2">Thông tin liên hệ nhanh</p>
                        <p class="mb-2 text-dark"><i class="fa-solid fa-phone text-muted me-2 w-15px"></i> @(string.IsNullOrEmpty(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</p>
                        <p class="mb-0 text-dark"><i class="fa-solid fa-location-dot text-muted me-2 w-15px"></i> @(string.IsNullOrEmpty(Model.Address) ? "Chưa cập nhật" : Model.Address)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-2 px-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary">
                        <i class="fa-solid fa-user-pen fs-5"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-0">Thông tin cá nhân</h5>
                </div>
                <div class="card-body p-4 pt-2">
                    <form action="~/Customer/UpdateInfo" method="post">

                        <div class="form-floating mb-3">
                            <input type="text" class="form-control rounded-3" id="customerName" name="customerName" value="@Model.CustomerName" placeholder="Họ và Tên" required />
                            <label for="customerName" class="text-muted">Họ và Tên</label>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" class="form-control rounded-3" id="phone" name="phone" value="@Model.Phone" placeholder="Số điện thoại" required />
                                    <label for="phone" class="text-muted">Số điện thoại</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="email" class="form-control rounded-3" id="email" name="email" value="@Model.Email" placeholder="Email" required />
                                    <label for="email" class="text-muted">Email</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-4">
                            <select class="form-select rounded-3" id="address" name="address" aria-label="Tỉnh / Thành phố">
                                @foreach (var item in await SelectListHelper.Provinces())
                                {
                                    if (item.Value == Model.Address)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                            <label for="address" class="text-muted">Tỉnh / Thành phố</label>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm fw-medium">
                                <i class="fa-solid fa-floppy-disk me-2"></i>Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-2 px-4 d-flex align-items-center">
                    <div class="bg-danger bg-opacity-10 p-2 rounded-3 me-3 text-danger">
                        <i class="fa-solid fa-shield-halved fs-5"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-0">Bảo mật & Mật khẩu</h5>
                </div>
                <div class="card-body p-4 pt-2">
                    <form action="~/Customer/ChangePassword" method="post">

                        <div class="form-floating mb-3">
                            <input type="password" class="form-control rounded-3" id="oldPassword" name="oldPassword" placeholder="Mật khẩu hiện tại" required />
                            <label for="oldPassword" class="text-muted">Mật khẩu hiện tại</label>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="password" class="form-control rounded-3" id="newPassword" name="newPassword" placeholder="Mật khẩu mới" required minlength="6" />
                                    <label for="newPassword" class="text-muted">Mật khẩu mới</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="password" class="form-control rounded-3" id="confirmPassword" name="confirmPassword" placeholder="Xác nhận mật khẩu" required minlength="6" />
                                    <label for="confirmPassword" class="text-muted">Xác nhận mật khẩu</label>
                                </div>
                            </div>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-outline-danger px-4 py-2 rounded-3 fw-medium">
                                <i class="fa-solid fa-key me-2"></i>Đổi mật khẩu
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>