@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<style>
    body {
        background-color: #f8fafc;
    }

    .completed-card {
        background: #ffffff;
        border: none;
        border-radius: 24px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        padding: 60px 40px;
    }

    .icon-wrapper {
        width: 100px;
        height: 100px;
        background: #ecfdf5;
        color: #10b981;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 30px;
        font-size: 3.5rem;
    }

    .order-title {
        color: #1e1b4b;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .btn-history {
        background-color: #4f46e5;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px 28px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-history:hover {
            background-color: #4338ca;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
            color: white;
        }

    .btn-home {
        background-color: #ffffff;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 14px 28px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-home:hover {
            background-color: #f1f5f9;
            color: #1e293b;
        }

    .support-text {
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid #f1f5f9;
        color: #94a3b8;
        font-size: 0.9rem;
    }
</style>

<div class="container my-5 py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <div class="completed-card">
                <div class="icon-wrapper">
                    <i class="bi bi-check-lg"></i>
                </div>

                <h1 class="order-title mb-3">Đặt hàng thành công!</h1>
                <p class="text-muted fs-5 mb-5 px-md-4">
                    Cảm ơn bạn đã lựa chọn dịch vụ của chúng tôi. Đơn hàng đã được hệ thống ghi nhận và sẽ sớm được vận chuyển đến bạn.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                    <a asp-action="History" class="btn btn-history text-uppercase">
                        Xem lịch sử đơn hàng
                    </a>
                    <a href="/" class="btn btn-home text-uppercase">
                        Tiếp tục mua hàng
                    </a>
                </div>

                <div class="support-text">
                    <p class="mb-1">Bạn cần hỗ trợ nhanh?</p>
                    <span class="fw-bold text-dark">Hotline: 1900 123 456</span>
                    <div class="mt-2">
                        <small>Email: support@litecommerce.com</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>