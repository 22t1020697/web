@model IEnumerable<SV22T1020697.Models.Catalog.Product>
@{
    ViewData["Title"] = "Cửa hàng trực tuyến";
}

<style>
    .product-item {
        transition: all 0.3s ease;
        border: none;
        border-radius: 15px;
        overflow: hidden;
        background: #fff;
        cursor: pointer;
    }

        .product-item:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
        }

    .img-container {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #fdfdfd;
        padding: 10px;
    }

        .img-container img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
        }

    .section-header {
        border-left: 5px solid #007bff;
        padding-left: 15px;
        font-weight: 800;
        text-transform: uppercase;
    }

    .btn-custom {
        border-radius: 25px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .btn-buy-now {
        background: linear-gradient(45deg, #00FFFF, #00FFFF);
        color: white;
        border: none;
    }

        .btn-buy-now:hover {
            background: linear-gradient(45deg, #00FFFF, #00FFFF);
            color: white;
        }
</style>

<div class="container mt-5">
    @* --- PHẦN SẢN PHẨM BÁN CHẠY --- *@
    <div class="mb-4">
        <h2 class="section-header text-primary">🔥 BEST SELLER</h2>
    </div>

    <div class="row mb-5">
        @if (ViewBag.BestSellers != null)
        {
            foreach (var item in ViewBag.BestSellers)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm product-item"
                         onclick="window.location.href='/Product/Detail/@item.ProductID'">

                        <div class="img-container">
                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                 alt="@item.ProductName"
                                 onerror="this.src='/images/products/nophoto.png'">
                        </div>
                        <div class="card-body d-flex flex-column text-center">
                            <h6 class="card-title text-truncate fw-bold">@item.ProductName</h6>
                            <p class="card-text text-danger fw-bold mb-3">@item.Price.ToString("N0") đ</p>

                            <div class="mt-auto d-grid gap-2">
                                <button type="button" class="btn btn-outline-primary btn-custom add-to-cart"
                                        data-id="@item.ProductID"
                                        onclick="event.stopPropagation();">
                                    <i class="fa fa-shopping-basket me-1"></i> + Giỏ hàng
                                </button>

                                <a href="/Cart/Add?id=@item.ProductID&quantity=1&redirect=true"
                                   class="btn btn-buy-now btn-custom"
                                   onclick="event.stopPropagation();">
                                    <i class="fa fa-bolt me-1"></i> Mua ngay
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @* --- PHẦN SẢN PHẨM MỚI --- *@
    <div class="mb-4">
        <h2 class="section-header text-success">✨ NEW</h2>
    </div>

    <div class="row">
        @if (ViewBag.NewProducts != null)
        {
            foreach (var item in ViewBag.NewProducts)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm product-item border-bottom border-success border-3"
                         onclick="window.location.href='/Product/Detail/@item.ProductID'">

                        <div class="img-container">
                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                 alt="@item.ProductName"
                                 onerror="this.src='/images/products/nophoto.png'">
                        </div>
                        <div class="card-body d-flex flex-column text-center">
                            <h6 class="card-title text-truncate fw-bold">@item.ProductName</h6>
                            <p class="card-text text-danger fw-bold mb-3">@item.Price.ToString("N0") đ</p>

                            <div class="mt-auto d-grid gap-2">
                                <button type="button" class="btn btn-outline-success btn-custom add-to-cart"
                                        data-id="@item.ProductID"
                                        onclick="event.stopPropagation();">
                                    <i class="fa fa-shopping-basket me-1"></i> + Giỏ hàng
                                </button>

                                <a href="@Url.Action("Add", "Cart", new { id = item.ProductID, quantity = 1, redirect = true })"
                                   class="btn btn-buy-now btn-custom"
                                   onclick="event.stopPropagation();">
                                    <i class="fa fa-bolt me-1"></i> Mua ngay
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        $(document).ready(function () {
            // Cấu hình thông báo
            toastr.options = {
                "positionClass": "toast-bottom-right",
                "timeOut": "2000",
                "progressBar": true
            };

            // Xử lý sự kiện click nút thêm vào giỏ
            $(".add-to-cart").click(function (e) {
                e.preventDefault();
                e.stopPropagation(); // Ngăn sự kiện click lan ra thẻ cha (card)

                var productId = $(this).data("id");
                var btn = $(this);

                // Vô hiệu hóa nút tạm thời để tránh click nhiều lần
                btn.prop("disabled", true);

                $.post("/Cart/Add", { id: productId, quantity: 1, redirect: false }, function (response) {
                    if (response.code === 1) {
                        // Cập nhật số lượng hiển thị trên Badge giỏ hàng ở Header
                        // Bạn cần đảm bảo thẻ Badge trong Layout có class là 'cart-badge'
                        $(".cart-badge, #cart-count").text(response.data);

                        toastr.success(response.message);
                    } else {
                        toastr.error(response.message);
                    }
                }).fail(function() {
                    toastr.error("Không thể kết nối đến máy chủ.");
                }).always(function() {
                    btn.prop("disabled", false);
                });
            });
        });
    </script>
}