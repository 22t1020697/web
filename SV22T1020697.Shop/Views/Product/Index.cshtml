@model SV22T1020697.Models.Common.PagedResult<SV22T1020697.Models.Catalog.Product>

<style>
    :root {
        --primary-gradient: linear-gradient(45deg, #007bff, #00d4ff);
        --orange-gradient: linear-gradient(45deg, #fd7e14, #ff922b);
        --bg-body: #f4f7f9;
        --text-dark: #2d3436;
        --border-light: #e1e8ed;
    }

    .product-grid-container {
        padding: 40px 0;
        background-color: var(--bg-body);
    }

    /* Card thiết kế hiện đại */
    .product-item {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: none;
        border-radius: 15px;
        overflow: hidden;
        background: #fff;
        cursor: pointer;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

        .product-item:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
        }

    .img-container {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #fdfdfd;
        padding: 15px;
        border-bottom: 1px solid var(--border-light);
    }

        .img-container img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: transform 0.5s;
        }

    .product-item:hover .img-container img {
        transform: scale(1.08);
    }

    .badge-store {
        background: #00d4ff;
        color: #000;
        font-size: 0.65rem;
        padding: 3px 10px;
        border-radius: 4px;
        font-weight: 800;
        margin-bottom: 10px;
        width: fit-content;
        text-transform: uppercase;
    }

    .card-body {
        padding: 1.25rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .p-name {
        color: var(--text-dark);
        font-weight: 700;
        font-size: 0.95rem;
        line-height: 1.4;
        margin-bottom: 8px;
        height: 42px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .p-price {
        color: #d63031;
        font-weight: 800;
        font-size: 1.1rem;
        margin-bottom: 15px;
    }

    .btn-custom {
        border-radius: 25px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.3px;
        padding: 8px 12px;
    }

    .btn-buy-now {
        background: var(--orange-gradient);
        color: white;
        border: none;
        transition: 0.3s;
    }

        .btn-buy-now:hover {
            background: linear-gradient(45deg, #e8590c, #fd7e14);
            color: white;
            box-shadow: 0 4px 12px rgba(253, 126, 20, 0.3);
        }

    /* Pagination */
    .pagination .page-link {
        color: var(--text-dark);
        border: none;
        margin: 0 5px;
        border-radius: 10px !important;
        font-weight: 600;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .pagination .page-item.active .page-link {
        background: var(--primary-gradient);
        color: white;
    }
</style>

<div class="product-grid-container">
    <div class="container">
        <div class="mb-5">
            <h2 style="border-left: 5px solid #007bff; padding-left: 15px; font-weight: 800; text-transform: uppercase;">
                Danh sách sản phẩm
            </h2>
        </div>

        <div class="row g-4">
            @if (Model.DataItems != null && Model.DataItems.Any())
            {
                foreach (var item in Model.DataItems)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card h-100 shadow-sm product-item"
                             onclick="window.location.href='/Product/Detail/@item.ProductID'">

                            <div class="img-container">
                                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                     alt="@item.ProductName"
                                     onerror="this.src='/images/products/nophoto.png'">
                            </div>

                            <div class="card-body">
                                <div class="badge-store">QN STORE</div>
                                <h6 class="p-name">@item.ProductName</h6>
                                <p class="p-price">@item.Price.ToString("N0") đ</p>

                                <div class="mt-auto d-grid gap-2">
                                    <button type="button" class="btn btn-outline-primary btn-custom add-to-cart"
                                            data-id="@item.ProductID"
                                            onclick="event.stopPropagation();">
                                        <i class="fa fa-shopping-basket me-1"></i> + Giỏ hàng
                                    </button>

                                    <a href="@Url.Action("Add", "Cart", new { id = item.ProductID, quantity = 1, redirect = true })"
                                       class="btn btn-buy-now btn-custom"
                                       onclick="event.stopPropagation();">
                                        <i class="fa fa-bolt me-1"></i> Mua ngay
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="alert alert-light border shadow-sm">
                        <i class="fa fa-search me-2"></i> Không tìm thấy sản phẩm nào phù hợp.
                    </div>
                </div>
            }
        </div>

        @if (Model.PageCount > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    @foreach (var pageItem in Model.GetDisplayPages())
                    {
                        if (pageItem.Page == 0)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        else
                        {
                            <li class="page-item @(pageItem.IsCurrent ? "active" : "")">
                                <a class="page-link" href="~/Product/Index?page=@pageItem.Page">@pageItem.Page</a>
                            </li>
                        }
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            // Cấu hình thông báo Toastr
            toastr.options = {
                "positionClass": "toast-bottom-right",
                "timeOut": "2000",
                "closeButton": true,
                "progressBar": true
            };

            // Xử lý sự kiện click nút "Thêm vào giỏ hàng"
            $(".add-to-cart").on("click", function (e) {
                e.preventDefault();
                e.stopPropagation(); // Ngăn chặn nhảy trang chi tiết

                var btn = $(this);
                var productId = btn.data("id");

                // Disable nút để tránh click liên tục
                btn.prop("disabled", true);

                $.ajax({
                    url: "/Cart/Add",
                    type: "POST", // Hoặc GET tùy theo Controller, ở đây dùng POST cho an toàn
                    data: { id: productId, quantity: 1, redirect: false },
                    success: function (response) {
                        if (response.code === 1) {
                            // Cập nhật số lượng trên Badge Header
                            // (.cart-badge hoặc #cart-count tùy theo Layout của bạn)
                            $(".cart-badge, #cart-count").text(response.data);

                            toastr.success(response.message);
                        } else {
                            toastr.error(response.message);
                        }
                    },
                    error: function () {
                        toastr.error("Không thể kết nối đến máy chủ.");
                    },
                    complete: function() {
                        btn.prop("disabled", false);
                    }
                });
            });
        });

        // Hàm Mua ngay
        function buyNow(id) {
            window.location.href = "/Cart/Add?id=" + id + "&quantity=1&redirect=true";
        }
    </script>
}