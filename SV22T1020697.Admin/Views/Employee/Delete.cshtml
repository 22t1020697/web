@model Employee
@{
    ViewBag.Title = "Xóa nhân viên";
}

@section PageToolBar {
    @if (ViewBag.AllowedDelete == true)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xác nhận xóa
        </button>
    }
    else
    {
        <button class="btn btn-danger" disabled>
            <i class="bi bi-trash"></i> Không thể xóa
        </button>
    }
    <a asp-controller="Employee" asp-action="Index"
         class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-person-x me-2"></i> Xác nhận xóa nhân viên
        </h3>
    </div>

    <div class="card-body">

        <form id="formDelete" method="post"
              asp-controller="Employee"
              asp-action="Delete"
              asp-route-id="@Model.EmployeeID">


            @if ((ViewBag.AllowDelete as bool?) == true)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    Bạn có chắc chắn muốn xóa nhân viên này không?
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    Nhân viên này không thể xóa vì đã có dữ liệu liên quan.
                </div>
            }

            <div class="row mt-4">
                <div class="col-md-2 text-center">
                    @* Hiển thị ảnh thực tế của nhân viên *@
                    <img src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         class="img-thumbnail mb-2"
                         style="width: 100%;"
                         alt="Ảnh nhân viên" />
                </div>

                <div class="col-md-10">
                    <dl class="row">
                        <dt class="col-sm-3">Họ và tên:</dt>
                        <dd class="col-sm-9">@Model.FullName</dd>

                        <dt class="col-sm-3">Ngày sinh:</dt>
                       <dd class="col-sm-9">@Model.BirthDate?.ToString("dd/MM/yyyy")</dd>
                        <dt class="col-sm-3">Điện thoại:</dt>
                        <dd class="col-sm-9">@Model.Phone</dd>

                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <dt class="col-sm-3">Địa chỉ:</dt>
                        <dd class="col-sm-9">@Model.Address</dd>

                        <dt class="col-sm-3">Trạng thái:</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsWorking==true)
                            {
                                <span class="badge bg-success">Đang làm việc</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã nghỉ việc</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </form>
    </div>
</div>