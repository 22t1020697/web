@{
    ViewBag.Title = "Thêm sản phẩm";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-cart-plus me-2"></i>THÊM SẢN PHẨM VÀO ĐƠN #12345</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Tìm sản phẩm</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" class="form-control" placeholder="Nhập mã hoặc tên sản phẩm để tìm...">
                            <button class="btn btn-primary px-4">Tìm</button>
                        </div>
                    </div>

                    <form action="/Order/AddProduct/1" method="post">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold text-muted small text-uppercase">Chọn sản phẩm từ danh sách</label>
                                <select name="ProductId" class="form-select">
                                    <option value="">-- Chọn sản phẩm --</option>
                                    <option value="101">Macbook Pro 14" M2 2023</option>
                                    <option value="102">iPhone 15 Pro Max</option>
                                    <option value="103">Bàn phím cơ Keychron K8 Pro</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Số lượng</label>
                                <input type="number" name="Quantity" class="form-control" value="1" min="1">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Đơn giá bán</label>
                                <div class="input-group">
                                    <input type="text" name="Price" class="form-control text-end fw-bold text-danger" value="0">
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>
                            <div class="col-12 mt-4">
                                <div class="alert alert-info border-0 small">
                                    <i class="bi bi-info-circle me-1"></i> Giá bán sẽ tự động hiển thị khi chọn sản phẩm, bạn có thể điều chỉnh nếu cần.
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-3">
                            <a href="/Order/Detail/1" class="btn btn-light border px-4">Quay lại</a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                <i class="bi bi-plus-lg me-1"></i>Thêm vào giỏ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>