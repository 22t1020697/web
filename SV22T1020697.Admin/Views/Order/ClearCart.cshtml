@{

}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác nhận xóa giỏ hàng</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        /* CSS tuỳ chỉnh để căn giữa box thông báo giữa màn hình */
        body {
            background-color: #f4f6f9; /* Màu nền nhẹ nhàng */
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .custom-dialog {
            background: #fff;
            border-radius: 0.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15); /* Đổ bóng tạo chiều sâu */
            width: 100%;
            max-width: 500px; /* Độ rộng tối đa */
            overflow: hidden;
        }
    </style>
</head>
<body>

    <div class="custom-dialog">
        <form asp-action="ClearCart" method="post">
            <div class="modal-header text-bg-danger p-3">
                <strong class="modal-title fs-5">
                    <i class="bi bi-trash3 me-2"></i> Xóa giỏ hàng
                </strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <div class="alert alert-danger d-flex align-items-center mb-0">
                    <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
                    <div>
                        Bạn có chắc chắn muốn xóa tất cả các mặt hàng trong giỏ hàng không? <strong>Hành động này không thể hoàn tác.</strong>
                    </div>
                </div>
            </div>

            <div class="modal-footer p-3 bg-light border-top d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal" onclick="window.history.back();">
                    Đóng
                </button>
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-check-lg me-1"></i> Chấp nhận
                </button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>