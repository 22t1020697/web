@{
    ViewBag.Title = "Chỉnh sửa đơn hàng";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning py-3">
                    <h5 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-pencil-square me-2"></i>CẬP NHẬT THÔNG TIN ĐƠN HÀNG #12345
                    </h5>
                </div>

                <div class="card-body p-4">
                    <form action="/Order/Edit/1" method="post">
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <h6 class="text-primary border-bottom pb-2 fw-bold">1. Thông tin khách hàng</h6>
                            </div>

                            <div class="col-md-7">
                                <label class="form-label small fw-semibold">Tên khách hàng</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input type="text" name="CustomerName" class="form-control" value="Nguyễn Văn A" required>
                                </div>
                            </div>

                            <div class="col-md-5">
                                <label class="form-label small fw-semibold">Số điện thoại</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                    <input type="text" name="Phone" class="form-control" value="0912345678">
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-semibold">Địa chỉ giao hàng</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                    <input type="text" name="Address" class="form-control" value="123 Đường ABC, Quận 1, TP.HCM">
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <h6 class="text-primary border-bottom pb-2 fw-bold">2. Trạng thái & Xử lý</h6>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Trạng thái đơn hàng</label>
                                <select name="Status" class="form-select form-select-sm">
                                    <option value="Pending" selected>Chờ duyệt</option>
                                    <option value="Approved">Đã duyệt</option>
                                    <option value="Shipping">Đang giao hàng</option>
                                    <option value="Completed">Hoàn thành</option>
                                    <option value="Cancelled">Đã hủy</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Nhân viên xử lý</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
                                    <select name="StaffName" class="form-select form-select-sm">
                                        <option value="Trần Thị B" selected>Trần Thị B</option>
                                        <option value="Lê Văn C">Lê Văn C</option>
                                        <option value="Phạm Minh D">Phạm Minh D</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Ngày đặt hàng</label>
                                <input type="text" class="form-control form-control-sm bg-light" value="10/10/2025" readonly>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Ngày cập nhật cuối</label>
                                <input type="text" class="form-control form-control-sm bg-light" value="@DateTime.Now.ToString("dd/MM/yyyy")" readonly>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Ghi chú nội bộ</label>
                                <textarea name="Note" class="form-control form-control-sm" rows="3" placeholder="Nhập ghi chú về đơn hàng nếu có..."></textarea>
                            </div>
                        </div>

                        <div class="card-footer bg-white px-0 pb-0 d-flex justify-content-between">
                            <a href="/Order/Index" class="btn btn-sm btn-light border px-4">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
                            </a>
                            <div class="btn-group">
                                <button type="reset" class="btn btn-sm btn-outline-secondary px-3">Khôi phục</button>
                                <button type="submit" class="btn btn-sm btn-primary px-4">
                                    <i class="bi bi-save me-1"></i>Lưu thay đổi
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>