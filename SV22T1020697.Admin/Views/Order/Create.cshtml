@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary" style="min-height:500px">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-search me-1"></i>Chọn mặt hàng cần bán</h6>
            </div>
            <div class="card-body pb-1">
                <!-- Search -->
                <form id="formSearch" method="get" action="/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event,this,1)">
                    <input type="hidden" asp-for="PageSize" />
                    <div class="input-group">
                        <input class="form-control" asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng..." autofocus />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
            <!-- Danh sách mặt hàng -->
            <div id="searchResult" class="p-2 overflow-auto" style="max-height:520px"></div>
        </div>
    </div>
           

           

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng -->
        <div id="cart" class="mb-3"></div>

        <!-- Form lập đơn -->
        <div class="card card-outline card-info">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-person me-1"></i>Thông tin khách hàng &amp; giao hàng</h6>
            </div>
            <div class="card-body">
                <form onsubmit="createOrder(event,this)">

                    <!-- Tìm khách hàng -->
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-semibold">
                            Khách hàng <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <div class="input-group">
                                <input type="text" id="customerSearch" class="form-control"
                                       placeholder="Nhập tên để tìm khách hàng..." autocomplete="off" />
                                <button type="button" class="btn btn-outline-secondary"
                                        onclick="searchCustomers()">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                            <select id="customerSelect" class="form-select mt-1"
                                    size="4" style="display:none">
                            </select>
                            <input type="hidden" id="customerIDHidden" name="customerID" value="0" />
                            <div id="customerInfo" class="mt-1 small text-success"></div>
                            <span id="customerValidationMessage" class="text-danger small d-block mt-1"></span>
                            <div id="orderCreateMessage" class="mt-2"></div>
                        </div>
                    </div>
                    <!-- Tỉnh/Thành -->
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-semibold">
                            Tỉnh/Thành <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <select class="form-select" name="deliveryProvince" id="deliveryProvince">
                                <option value="">-- Chọn tỉnh/thành --</option>
                                @foreach (var p in await SelectListHelper.ProvincesAsync())
                                {
                                    if (p.Value != "")
                                    {
                                        <option value="@p.Value">@p.Text</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Địa chỉ -->
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-semibold">
                            Địa chỉ <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <textarea class="form-control" name="deliveryAddress" id="deliveryAddress"
                                      rows="2" placeholder="Số nhà, tên đường, phường/xã..."></textarea>
                        </div>
                    </div>

                    <div class="text-end">
                        <button class="btn btn-success btn-lg">
                            <i class="bi bi-check-circle me-1"></i>Lập đơn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // 1. Khởi tạo danh sách sản phẩm
            doSearch(1);

            // 2. Load giỏ hàng
            showCart();

            // 3. Xử lý sự kiện Submit Form Search
            $("#formSearch").submit(function (e) {
                e.preventDefault();
                doSearch(1);
            });

            // 4. Xử lý Submit Form Lập đơn
            $("#formCreateOrder").submit(function (e) {
                e.preventDefault();
                createOrder(this);
            });

            // 5. Sự kiện chọn khách hàng từ select
            $("#customerSelect").change(selectCustomer);
        });

        function doSearch(page) {
            var form = $("#formSearch");
            if (typeof paginationSearch === "function") {
                paginationSearch(null, form[0], page);
            }
        }

        function showCart() {
            $.get('/Order/ShowCart', function (html) {
                $("#cart").html(html);
            }).fail(function () {
                console.error("Lỗi tải giỏ hàng");
            });
        }

        function addCartItem(event, form) {
            event.preventDefault();
            var formData = $(form).serialize();
            $.post("/Order/AddCartItem", formData, function (result) {
                if (result.code === 1) showCart();
                else alert(result.message);
            });
        }

        // --- PHẦN SỬA LỖI MODAL ---

        function editCartItem(productID) {
            $.get("/Order/EditCartItem", { productId: productID }, function (html) {
                // Nạp HTML vào .modal-content của dialogModal (layout dùng chung)
                $("#dialogModal .modal-content").html(html);
                var myModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('dialogModal'));
                myModal.show();
            });
        }

        function deleteCartItem(productID) {
            if(confirm("Xóa mặt hàng này khỏi giỏ?")) {
                $.post("/Order/DeleteCartItem", { productID: productID }, function (result) {
                    if (result.code === 1) showCart();
                });
            }
        }

        function confirmClearCart() {
            $.get("/Order/ClearCart", function (html) {
                // Nạp vào modal-content và hiển thị
                $("#dialogModal .modal-content").html(html);
                var myModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('dialogModal'));
                myModal.show();
            }).fail(function() {
                alert("Không thể tải xác nhận xóa.");
            });
        }

        function clearCart() {
            $.post("/Order/ClearCart", function (result) {
                if (result.code === 1) {
                    var myModal = bootstrap.Modal.getInstance(document.getElementById('dialogModal'));
                    if (myModal) myModal.hide();
                    showCart();
                }
            });
        }

        function updateCartItem(event, form) {
            event.preventDefault();
            $.post("/Order/UpdateCartItem", $(form).serialize(), function (result) {
                if (result.code === 1) {
                    var myModal = bootstrap.Modal.getInstance(document.getElementById('dialogModal'));
                    if (myModal) myModal.hide();
                    showCart();
                } else alert(result.message);
            });
        }

        // --- PHẦN KHÁCH HÀNG & ĐƠN HÀNG ---

        function createOrder(form) {
            var customerID = $("#customerIDHidden").val();
            if (customerID == "0") {
                alert("Vui lòng chọn khách hàng trước khi lập đơn.");
                return;
            }
            $.post("/Order/CreateOrder", $(form).serialize(), function (result) {
                if (result.code === 1) window.location.href = "/Order";
                else alert(result.message);
            });
        }

        function searchCustomers() {
            var keyword = $("#customerSearch").val();
            if (keyword.length < 2) {
                alert("Vui lòng nhập ít nhất 2 ký tự để tìm.");
                return;
            }
            $.getJSON("/Order/GetCustomers", { searchValue: keyword }, function (data) {
                var select = $("#customerSelect");
                select.empty().show();
                if (data.length === 0) {
                    select.append("<option disabled>Không tìm thấy khách hàng</option>");
                } else {
                    customerList = data;
                    $.each(data, function (i, c) {
                        select.append($('<option>', { value: c.id, text: c.name + " - " + (c.phone || "") }));
                    });
                }
            });
        }

        var customerList = [];

        function selectCustomer() {
            var selectedId = $(this).val();
            var customer = customerList.find(x => x.id == selectedId);
            if (customer) {
                $("#customerIDHidden").val(customer.id);
                $("#customerInfo").html("Đã chọn: <b>" + customer.name + "</b>");
                $("#deliveryAddress").val(customer.address || "");
                $("#deliveryProvince").val(customer.province || "");
                $("#customerSelect").hide();
                $("#customerSearch").val(customer.name);
            }
        }
    </script>
}