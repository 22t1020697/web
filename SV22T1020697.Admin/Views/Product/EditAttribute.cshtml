@model SV22T1020697.Models.Catalog.ProductAttribute
@{

    ViewBag.Title = "Sửa thuộc tính";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">@ViewBag.Title</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/SaveAttribute" method="post">
                    <input type="hidden" asp-for="AttributeID" />
                    <input type="hidden" asp-for="ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Tên thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   asp-for="AttributeName"
                                   class="form-control"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   required autofocus />
                            @Html.ValidationMessageFor(m => m.AttributeName, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Giá trị thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   asp-for="AttributeValue"
                                   class="form-control"
                                   placeholder="Ví dụ: Đỏ, XL, 500g"
                                   required />
                            @Html.ValidationMessageFor(m => m.AttributeValue, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">
                            Thứ tự hiển thị
                        </label>
                        <div class="col-sm-3">
                            <input type="number"
                                   asp-for="DisplayOrder"
                                   class="form-control"
                                   min="1" />
                            @Html.ValidationMessageFor(m => m.DisplayOrder, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </form>
            </div>
        </div>
    </div>
</div>