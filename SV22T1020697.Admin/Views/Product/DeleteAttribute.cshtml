@model SV22T1020697.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Xóa thuộc tính sản phẩm";
}

@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i> Xác nhận xóa
    </button>
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Xác nhận xóa thuộc tính
                    </h5>
                </div>

                <div class="card-body">

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                        <div>
                            Bạn có chắc chắn muốn <strong>xóa thuộc tính</strong> này khỏi sản phẩm không?
                        </div>
                    </div>

                    <table class="table table-bordered mb-0">
                        <tr>
                            <th class="bg-light" width="35%">Tên thuộc tính</th>
                            <td class="fw-bold text-primary">@Model.AttributeName</td>
                        </tr>
                        <tr>
                            <th class="bg-light">Giá trị</th>
                            <td>@Model.AttributeValue</td>
                        </tr>
                        <tr>
                            <th class="bg-light">Thứ tự hiển thị</th>
                            <td>@Model.DisplayOrder</td>
                        </tr>
                    </table>

                    @* Form chuẩn sử dụng hidden input để gửi POST tới Controller *@
                    <form id="formDelete" method="post" action="~/Product/DeleteAttribute">
                        <input type="hidden" name="attributeId" value="@Model.AttributeID" />
                        <input type="hidden" name="productId" value="@Model.ProductID" />
                    </form>

                </div>
            </div>

            <div class="text-center mt-3 text-muted">
                <small><i class="bi bi-lock"></i> Hành động này không thể hoàn tác sau khi xác nhận.</small>
            </div>

        </div>
    </div>
</div>