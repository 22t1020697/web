@{
    ViewBag.Title = "Xóa thuộc tính sản phẩm";
}

<div class="container-fluid mt-4">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <!-- Card -->
            <div class="card border-danger shadow-sm">

                <!-- Header -->
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-triangle"></i>
                        Xác nhận xóa thuộc tính
                    </h5>
                </div>

                <!-- Body -->
                <div class="card-body">

                    <div class="alert alert-warning">
                        <i class="bi bi-info-circle"></i>
                        Bạn có chắc chắn muốn <strong>xóa thuộc tính</strong> sau không?
                    </div>

                    <!-- Thông tin thuộc tính -->
                    <table class="table table-bordered">
                        <tr>
                            <th width="35%">Tên thuộc tính</th>
                            <td>Hạn sử dụng</td>
                        </tr>
                        <tr>
                            <th>Giá trị</th>
                            <td>6 tháng</td>
                        </tr>
                        <tr>
                            <th>Thứ tự</th>
                            <td>1</td>
                        </tr>
                    </table>

                    <!-- Form -->
                    <form method="post" action="/Product/DeleteAttribute/1?attributeId=1">
                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Product/ListAttributes/1"
                               class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Hủy
                            </a>

                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Xác nhận xóa
                            </button>
                        </div>
                    </form>

                </div>

            </div>

        </div>
    </div>
</div>