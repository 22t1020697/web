@model SV22T1020697.Models.Catalog.ProductPhoto
@{
    // ViewBag.Title được truyền từ Controller (Bổ sung ảnh hoặc Thay đổi ảnh)
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save me-1"></i>
        Lưu ảnh
    </button>

    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0">@ViewBag.Title</h5>
            </div>

            <div class="card-body">
                @* Hiển thị thông báo lỗi/thành công *@
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle me-1"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form id="formEdit" action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
                    @* Các trường ẩn để định danh *@
                    <input type="hidden" asp-for="PhotoID" />
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="Photo" />

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Chọn file ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            @Html.ValidationMessage("Photo", "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            @{
                                // Xử lý đường dẫn ảnh thông minh
                                string imagePath = "/images/products/nophoto.png";
                                if (!string.IsNullOrEmpty(Model.Photo))
                                {
                                    if (Model.Photo.StartsWith("products/", StringComparison.OrdinalIgnoreCase))
                                        imagePath = $"/images/{Model.Photo}";
                                    else
                                        imagePath = $"/images/products/{Model.Photo}";
                                }
                            }
                            <img id="imgPreview"
                                 src="@imagePath"
                                 onerror="this.src='/images/products/nophoto.png'"
                                 class="img-thumbnail"
                                 style="max-height:200px; object-fit:cover;" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả <span class="text-danger">*</span></label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="Description" class="form-control" placeholder="Mô tả ngắn gọn về ảnh..." autofocus />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" asp-for="DisplayOrder" class="form-control" min="1" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input" type="checkbox" asp-for="IsHidden" id="IsHidden" style="cursor:pointer" />
                                <label class="form-check-label" for="IsHidden" style="cursor:pointer">
                                    Ẩn ảnh này (Không cho khách hàng thấy)
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>