@{
    ViewBag.Title = "Xóa hình ảnh sản phẩm";

    // ===== DỮ LIỆU MẪU (DEMO) =====
    int productId = 1;
    int photoId = 101;

    var photo = new
    {
        PhotoID = photoId,
        ImageUrl = "/images/products/sample.jpg",
        Description = "Hình mặt trước sản phẩm"
    };

    var product = new
    {
        ProductID = productId,
        ProductName = "Sữa tươi Vinamilk"
    };
}

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card card-danger card-outline">

            <!-- ===== HEADER ===== -->
            <div class="card-header">
                <h3 class="card-title text-danger">
                    <i class="bi bi-trash me-2"></i>
                    Xóa hình ảnh sản phẩm
                </h3>
            </div>

            <!-- ===== BODY ===== -->
            <div class="card-body">
                <form method="post">

                    <input type="hidden" name="ProductID" value="@product.ProductID" />
                    <input type="hidden" name="PhotoID" value="@photo.PhotoID" />

                    <div class="alert alert-warning">
                        Bạn có chắc chắn muốn <strong>xóa hình ảnh</strong> của sản phẩm:
                        <strong>@product.ProductName</strong>?
                    </div>

                    <!-- Preview hình ảnh -->
                    <div class="text-center mb-3">
                        <img src="@photo.ImageUrl"
                             class="img-thumbnail"
                             style="max-height:200px"
                             alt="Product photo" />
                    </div>

                    <!-- Mô tả -->
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <input type="text"
                               class="form-control"
                               value="@photo.Description"
                               readonly />
                    </div>

                    <!-- Buttons -->
                    <div class="text-end">
                        <button type="submit"
                                class="btn btn-danger">
                            <i class="bi bi-trash"></i> Xóa hình ảnh
                        </button>

                        <a href="~/Product/ListPhotos/@product.ProductID"
                           class="btn btn-secondary ms-2">
                            <i class="bi bi-x-circle"></i> Hủy
                        </a>
                    </div>

                </form>
            </div>

        </div>

    </div>
</div>
