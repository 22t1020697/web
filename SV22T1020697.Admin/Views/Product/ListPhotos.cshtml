@model SV22T1020697.Models.Catalog.Product
@{
    Layout = null;
    // Lấy danh sách ảnh từ ViewBag đã được truyền từ Controller
    var photos = ViewBag.Photos as IEnumerable<SV22T1020697.Models.Catalog.ProductPhoto>;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@Model.ProductID">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                @* Đổi p-1 thành p-0 để bảng sát lề card cho đẹp *@
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px" class="text-center">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:100px" class="text-center">Thứ tự</th>
                            <th style="width:100px" class="text-center">Hiển thị</th>
                            <th style="width:100px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (photos != null && photos.Any())
                        {
                            foreach (var item in photos)
                            {
                                <tr>
                                    <td class="text-center align-middle">
                                        @* Xử lý đường dẫn ảnh thông minh để tránh lỗi vỡ ảnh *@
                                        <img src="@((string.IsNullOrEmpty(item.Photo))
                                                                                                                                                  ? "/images/products/nophoto.png"
                                                                                                                                                  : (item.Photo.StartsWith("products/", StringComparison.OrdinalIgnoreCase)
                                                                                                                                                      ? $"/images/{item.Photo}"
                                                                                                                                                      : $"/images/products/{item.Photo}"))"
                                     onerror="this.src='/images/products/nophoto.png'"
                                     class="img-thumbnail"
                                     style="height:60px; width:60px; object-fit:cover;" />
                            </td>
                            <td class="align-middle">@item.Description</td>
                            <td class="text-center align-middle">@item.DisplayOrder</td>
                            <td class="text-center align-middle">
                                @if (!item.IsHidden)
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Ẩn</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap align-middle">
                                        <a class="btn btn-sm btn-outline-primary" href="~/Product/EditPhoto/@item.ProductID?photoId=@item.PhotoID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-outline-danger" href="~/Product/DeletePhoto/@item.ProductID?photoId=@item.PhotoID">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-3">
                                    Sản phẩm này chưa có ảnh nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>